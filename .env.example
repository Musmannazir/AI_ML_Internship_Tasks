# Optional API Keys for Task 4 - General Health Query Chatbot
# Leave empty to use local mode (no API required)

# OpenAI API Key (must start with sk- for valid OpenAI keys)
# Get it from: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=

# Hugging Face API Key
# Get it from: https://huggingface.co/settings/tokens
HF_API_KEY=

# Optional: Specify the model to use with Hugging Face
# Default: mistralai/Mistral-7B-Instruct-v0.2 (or google/flan-t5-base if Mistral unavailable)
HF_MODEL=google/flan-t5-base

# Optional: Specify the model to use with OpenAI
# Default: gpt-3.5-turbo
OPENAI_MODEL=gpt-3.5-turbo
